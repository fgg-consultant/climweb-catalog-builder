generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model WmsSource {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  url             String
  description     String?
  lastFetched     DateTime? @map("last_fetched")
  rawCapabilities Json?     @map("raw_capabilities") @db.JsonB
  layerCount      Int       @default(0) @map("layer_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("wms_sources")
}

model Catalog {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entries  CatalogEntry[]
  versions CatalogVersion[]

  @@map("catalogs")
}

model CatalogVersion {
  id            String   @id @default(uuid()) @db.Uuid
  catalogId     String   @map("catalog_id") @db.Uuid
  versionNumber Int      @map("version_number")
  data          Json     @db.JsonB
  changeSummary String?  @map("change_summary")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@unique([catalogId, versionNumber])
  @@map("catalog_versions")
}

model Category {
  id          String     @id
  name        Json       @db.JsonB // TranslatableString
  description Json?      @db.JsonB // TranslatableString
  icon        String?
  sortOrder   Int        @default(0) @map("sort_order")
  parentId    String?    @map("parent_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryTree")

  @@index([parentId])
  @@map("categories")
}

model CatalogEntry {
  id            String  @id @default(uuid()) @db.Uuid
  catalogId     String  @map("catalog_id") @db.Uuid
  productCode   String  @map("product_code")
  category      Json    @db.JsonB // { title: TranslatableString, icon: string }
  subcategory   Json    @db.JsonB // { title: TranslatableString }
  datasetConfig Json    @map("dataset_config") @db.JsonB
  layerConfig   Json    @map("layer_config") @db.JsonB
  enabled       Boolean @default(true)
  origin        String  @default("config") // config | manual | wms_import
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@unique([catalogId, productCode])
  @@index([catalogId])
  @@map("catalog_entries")
}
